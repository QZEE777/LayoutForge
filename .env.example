# CloudConvert API Key - get free key at cloudconvert.com/dashboard/api/v2/keys
# Free tier: 10 conversions/day. Add this to Vercel environment variables.
CLOUDCONVERT_API_KEY=your_api_key_here

# Optional: for local dev without CloudConvert, leave blank and the
# fallback pdf-lib renderer will be used (no formatting preserved)

# Anthropic API Key - for Amazon Description Generator (description-generator)
# Get key at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Back office: secret to view captured leads at /admin and GET /api/admin/leads
# If unset, the leads API returns 503.
ADMIN_SECRET=your_admin_secret_here

# Supabase (auth + profiles + usage). Run supabase/migrations/001_profiles_usage_auth.sql in SQL Editor.
# Required for auth/session: without these, the app still runs but login and protected routes won't work.
# Find URL and keys at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# When true, non-founders are limited to 10 free uses (api/track-usage returns 403 after that).
PAYWALL_ACTIVE=false
# Optional: set to "true" to show upgrade prompt in UsageBanner when at limit.
NEXT_PUBLIC_PAYWALL_ACTIVE=false

# App URL for checkout redirects and webhooks (e.g. https://layout-forge.vercel.app)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Lemon Squeezy (payment gateway) — from dashboard.lemonsqueezy.com
LEMONSQUEEZY_API_KEY=your_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
# Single-use product variant ($9) — Lemon Squeezy variant ID 1346943
LEMONSQUEEZY_SINGLE_USE_VARIANT_ID=1346943
# Webhook signing secret (from Lemon Squeezy → Settings → Webhooks)
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Beta access code for payment overlay / bypass
BETA_ACCESS_CODE=MANU2PRINT-BETA

# Admin dashboard password for manu2print /admin (required)
ADMIN_PASSWORD_MANU2=your-password-here

# 32-character key for download tokens / encryption (src/lib/encryption.ts). Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=your_32_char_hex_key

# KDP PDF Checker: full 25-rule preflight (optional). When set, /api/kdp-pdf-check uses this API for files ≤4 MB.
# Set to the live preflight API URL (e.g. https://layoutforge.onrender.com). See kdp-preflight-engine/DEPLOY-LIVE.md.
KDP_PREFLIGHT_API_URL=

# Same URL as above, but exposed to the browser so files >4 MB can upload directly to preflight (avoids Vercel body limit). Set in Vercel to the same value as KDP_PREFLIGHT_API_URL.
NEXT_PUBLIC_KDP_PREFLIGHT_API_URL=

# Cloudflare R2 persistent storage (replaces /tmp when USE_R2=true). Create bucket in Cloudflare dashboard; create API token with R2 read/write.
USE_R2=true
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_here
R2_BUCKET_NAME=manu2print-uploads
