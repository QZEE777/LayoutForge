# KDP Preflight Engine — environment example
# Copy to .env and fill in values.

# App
DEBUG=false

# Security
MAX_UPLOAD_BYTES=104857600
# Optional ClamAV (e.g. Docker service name)
# CLAMAV_HOST=clamav:3310
# CLAMAV_TIMEOUT_SECONDS=10

# Redis (required for Celery and job store)
REDIS_URL=redis://localhost:6379/0

# Optional: override Celery broker/backend
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Storage: local (default) or s3/r2
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./data/uploads

# For S3/R2 (when STORAGE_PROVIDER=s3 or r2)
# S3_ENDPOINT_URL=
# S3_REGION=auto
# S3_BUCKET=kdp-preflight-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
